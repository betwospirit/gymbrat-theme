<section class="story{% if section.settings.reverse %} story--reverse{% endif %}" data-section-id="{{ section.id }}">
  <div class="story__media">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1600 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy">
    {%- else -%}
      <div style="background:linear-gradient(140deg,#1a1c2a,#0d0b14);width:100%;height:100%;"></div>
    {%- endif -%}
  </div>
  <div class="story__body">
    <span class="eyebrow accent">{{ section.settings.eyebrow }}</span>
    <h2 class="story__title">{{ section.settings.title }}</h2>
    <p class="story__text">{{ section.settings.body }}</p>
    {%- if section.settings.cta_url != blank -%}
      <p style="margin-top:8px;"><a class="ulink eyebrow" href="{{ section.settings.cta_url }}">{{ section.settings.cta_label }} →</a></p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Editorial story",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FROM THE FLOOR" },
    { "type": "text", "id": "title", "label": "Title", "default": "WE TRAIN IN WHAT WE MAKE." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Gymbrat started in a Gurgaon garage with one rule — if it can't survive a year of squats, it doesn't ship. Every prototype gets worn through a full block before it earns a SKU. Nothing leaves the studio because it looks good in a photo." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Read the story" },
    { "type": "url", "id": "cta_url", "label": "CTA url" },
    { "type": "checkbox", "id": "reverse", "label": "Reverse layout", "default": false }
  ],
  "presets": [{ "name": "Editorial story" }]
}
{% endschema %}
