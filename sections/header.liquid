<header class="site-header" data-section-id="{{ section.id }}">
  <a class="site-header__brand site-header__brand--logo" href="/" aria-label="{{ settings.brand_wordmark | default: shop.name }}">
    <img src="{{ 'gymbrat-logo.svg' | asset_url }}" alt="{{ settings.brand_wordmark | default: shop.name }}">
    <span class="site-header__mobile-wordmark">{{ settings.brand_wordmark | default: shop.name }}</span>
  </a>

  <nav class="site-header__center" aria-label="Primary">
    {%- for link in linklists[section.settings.menu].links -%}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {%- else -%}
      <a href="/collections/all">All Products</a>
      <a href="/collections">Collections</a>
      <a href="/pages/contact">Contact</a>
    {%- endfor -%}
  </nav>

  <button class="menu-toggle" data-drawer-toggle="MobileMenu" aria-controls="MobileMenu">
    {% render 'icons', icon: 'menu' %} Menu
  </button>

  <div class="site-header__corner" role="group" aria-label="Cart and shop">
    <button class="corner-cta corner-cta--cart" data-drawer-toggle="CartDrawer" aria-controls="CartDrawer">
      <span class="corner-cta__label">Cart</span>
      <span class="corner-cta__mobile-icon" aria-hidden="true">{% render 'icons', icon: 'bag' %}</span>
      <span class="corner-cta__count" data-cart-count>{{ cart.item_count | prepend: '0' | slice: -2, 2 }}</span>
    </button>
    <a class="corner-cta corner-cta--shop" href="/collections/all">
      Shop
      <span class="corner-cta__icon" aria-hidden="true">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="2" height="2" fill="#0D0B14"/>
          <rect y="4" width="2" height="2" fill="#0D0B14"/>
          <rect y="8" width="2" height="2" fill="#0D0B14"/>
          <rect x="4" width="2" height="2" fill="#0D0B14"/>
          <rect x="4" y="4" width="2" height="2" fill="#0D0B14"/>
          <rect x="4" y="8" width="2" height="2" fill="#0D0B14"/>
          <rect x="8" width="2" height="2" fill="#0D0B14"/>
          <rect x="8" y="4" width="2" height="2" fill="#0D0B14"/>
          <rect x="8" y="8" width="2" height="2" fill="#0D0B14"/>
        </svg>
      </span>
    </a>
  </div>
</header>

{%- comment -%} Mobile menu {%- endcomment -%}
<div class="drawer drawer--left" id="MobileMenu" aria-hidden="true">
  <div class="drawer__scrim" data-drawer-close></div>
  <div class="drawer__panel">
    <div class="drawer__head">
      <span class="smallcaps">Menu</span>
      <button data-drawer-close aria-label="Close">{% render 'icons', icon: 'close' %}</button>
    </div>
    <div class="drawer__body">
      <ul class="menu-list">
        {%- for link in linklists[section.settings.menu].links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- else -%}
          <li><a href="/collections/all">Shop all</a></li>
          <li><a href="/collections/new">New drops</a></li>
          <li><a href="/pages/lookbook">Lookbook</a></li>
          <li><a href="/pages/about">About</a></li>
        {%- endfor -%}
      </ul>
    </div>
    <div class="drawer__foot">
      <a class="ulink eyebrow" href="{{ routes.account_url }}">Sign in</a>
    </div>
  </div>
</div>

{%- comment -%} Cart drawer {%- endcomment -%}
<div class="drawer cart-drawer" id="CartDrawer" aria-hidden="true">
  <div class="drawer__scrim" data-drawer-close></div>
  <div class="drawer__panel cart-drawer__panel">
    <div class="cart-drawer__header">
      <div class="cart-drawer__count">
        <span data-cart-count>{{ cart.item_count | prepend: '0' | slice: -2, 2 }}</span>
        ITEMS IN YOUR CART
      </div>
      <button class="cart-drawer__close" data-drawer-close aria-label="Close">
        CLOSE
        <span class="cart-drawer__close-icon" aria-hidden="true"></span>
      </button>
    </div>

    <div class="cart-drawer__body">
      {%- if cart.item_count > 0 -%}
        <ul class="cart-drawer__list">
          {%- for item in cart.items -%}
            <li class="cart-drawer__item">
              <a class="cart-drawer__item-media" href="{{ item.url }}">
                {%- if item.image -%}<img src="{{ item.image | image_url: width: 320 }}" alt="" loading="lazy">{%- endif -%}
              </a>
              <div class="cart-drawer__item-info">
                <a class="cart-drawer__item-title" href="{{ item.url }}">{{ item.product.title }}</a>
                <div class="cart-drawer__item-price">{{ item.original_price | money }}</div>
                {%- if item.options_with_values.size > 0 and item.variant.title != 'Default Title' -%}
                  <dl class="cart-drawer__item-options">
                    {%- for option in item.options_with_values -%}
                      <div class="cart-drawer__item-option">
                        <dt>{{ option.name }}:</dt>
                        <dd>{{ option.value }}</dd>
                      </div>
                    {%- endfor -%}
                  </dl>
                {%- endif -%}
              </div>
              <a class="cart-drawer__item-remove" href="{{ item.url_to_remove }}" aria-label="Remove {{ item.product.title }}">
                <span class="cart-drawer__item-remove-icon" aria-hidden="true"></span>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <div class="cart-drawer__empty">
          <h3 class="cart-drawer__empty-title">Your cart is empty</h3>
          <a href="/collections/all" class="cart-drawer__cta cart-drawer__cta--white">
            <span>CONTINUE SHOPPING</span>
            <span class="cart-drawer__cta-arrow" aria-hidden="true"></span>
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer">
        <div class="cart-drawer__totals">
          <span class="cart-drawer__totals-label">Total</span>
          <span class="cart-drawer__totals-value">{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-drawer__tax-note">Taxes, discounts and <a href="/policies/shipping-policy">shipping</a> calculated at checkout.</p>
        <div class="cart-drawer__ctas">
          <a class="cart-drawer__cta cart-drawer__cta--white" href="/cart">
            <span>VIEW CART</span>
            <span class="cart-drawer__cta-arrow" aria-hidden="true"></span>
          </a>
          <a class="cart-drawer__cta cart-drawer__cta--accent" href="/checkout">
            <span>CHECK OUT</span>
            <span class="cart-drawer__cta-arrow" aria-hidden="true"></span>
          </a>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{ "name": "Header", "settings": [{ "type": "link_list", "id": "menu", "label": "Primary menu", "default": "main-menu" }] }
{% endschema %}
