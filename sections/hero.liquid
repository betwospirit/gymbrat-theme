<section class="hero{% if section.settings.media_only %} hero--media-only{% endif %}" data-section-id="{{ section.id }}">
  <div class="hero__media">
    {%- if section.settings.video_asset != blank -%}
      <video src="{{ section.settings.video_asset | asset_url }}" autoplay muted loop playsinline preload="auto"
        {% if section.settings.image != blank %}poster="{{ section.settings.image | image_url: width: 1600 }}"{% endif %}></video>
    {%- elsif section.settings.video_url != blank -%}
      <video src="{{ section.settings.video_url }}" autoplay muted loop playsinline preload="auto"
        {% if section.settings.image != blank %}poster="{{ section.settings.image | image_url: width: 1600 }}"{% endif %}></video>
    {%- elsif section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2400 }}" alt="{{ section.settings.image.alt | escape }}" loading="eager">
    {%- else -%}
      <div style="background:linear-gradient(160deg,#1a1c2a,#0d0b14);width:100%;height:100%;"></div>
    {%- endif -%}
  </div>

  {%- unless section.settings.media_only -%}
  <div class="hero__overlay">
    <div class="hero__chip-row">
      <a class="hero__scroll" href="#after-hero">{% render 'icons', icon: 'arrow-down' %} {{ section.settings.scroll_label }}</a>
      <span class="hero__center-chip">{% render 'icons', icon: 'spark' %} {{ section.settings.center_chip }}</span>
      <span class="hero__right-chip">{{ section.settings.right_chip }} {% render 'icons', icon: 'globe' %}</span>
    </div>

    <div class="hero__title-row">
      <h1 class="hero__title">
        {{ section.settings.title }}<span class="accent-dot" aria-hidden="true"></span>
      </h1>
      {%- if section.settings.cta_url != blank -%}
        <div class="hero__cta-block">
          <a href="{{ section.settings.cta_url }}" class="hero__cta hero__cta--stack">
            <span>{{ section.settings.cta_top }}</span>
            <span style="display:inline-flex;align-items:center;gap:10px;">{{ section.settings.cta_bottom }} <span class="hero__cta-arrow">{% render 'icons', icon: 'arrow-down' %}</span></span>
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
  {%- endunless -%}
</section>
<div id="after-hero"></div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "video_asset", "label": "Video asset filename" },
    { "type": "url", "id": "video_url", "label": "Video URL (mp4)" },
    { "type": "image_picker", "id": "image", "label": "Poster / fallback image" },
    { "type": "checkbox", "id": "media_only", "label": "Media only (no overlay)", "default": false },
    { "type": "text", "id": "scroll_label", "label": "Scroll label", "default": "SCROLL TO EXPLORE" },
    { "type": "text", "id": "center_chip", "label": "Center chip", "default": "TRAINED HARD, BUILT HARDER" },
    { "type": "text", "id": "right_chip", "label": "Right chip", "default": "MADE IN INDIA" },
    { "type": "text", "id": "title", "label": "Title", "default": "Built for the work, not the highlight reel" },
    { "type": "text", "id": "cta_top", "label": "CTA top line", "default": "DISCOVER" },
    { "type": "text", "id": "cta_bottom", "label": "CTA bottom line", "default": "OUR GEAR" },
    { "type": "url", "id": "cta_url", "label": "CTA url" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
